#!/usr/bin/env bash
# Host-side wrapper for the dockerized `wife` CLI.
# Resolves the repo's docker-compose.yml so this can be invoked from any cwd
# (e.g. by symlinking ~/.local/bin/wife -> /path/to/repo/bin/wife).
set -euo pipefail

# Resolve symlinks portably (macOS has no `readlink -f`).
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
REPO_DIR="$(dirname "$SCRIPT_DIR")"

exec docker compose --project-directory "$REPO_DIR" -f "$REPO_DIR/docker-compose.yml" run --rm sender "$@"
